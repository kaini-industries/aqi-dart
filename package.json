{
  "name": "air-equivalent",
  "version": "0.1.0",
  "private": true,
  "description": "A map-first AQI viewer that translates raw PM2.5 into a carefully framed cigarette-equivalent analogy.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "pnpm typecheck && pnpm test && pnpm build"
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@11.9.0",
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "csv-parse": "^7.0.1",
    "lucide-react": "^1.24.0",
    "maplibre-gl": "^5.24.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.10"
  }
}
