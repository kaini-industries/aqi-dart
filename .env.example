# Optional: a Neon/Postgres connection string. Without it, the app still serves
# live AirNow data and falls back to bundled demonstration readings if upstream
# data are temporarily unavailable.
DATABASE_URL=

# Required only for scheduled collection. Vercel Cron or the optional GitHub
# Actions workflow sends this value as a Bearer token.
CRON_SECRET=

# Optional override for the source file host, useful in tests or mirrors.
AIRNOW_BASE_URL=https://files.airnowtech.org

# Optional basemap style. The default requires no API key.
NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/positron
